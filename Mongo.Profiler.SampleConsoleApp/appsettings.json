{
  "ConnectionString": "mongodb://localhost:27017",
  "DatabaseName": "profiler_samples",
  "CollectionName": "orders",
  "GrpcPort": 5179,
  "EnableIndexAdvisor": true,
  "IndexAdvisorSlowQueryThresholdMs": 300,
  "IndexAdvisorMinDocsExaminedForWarning": 200,
  "IndexAdvisorMaxAnalysesPerFingerprintPerMinute": 1,
  "IndexAdvisorExplainTimeoutMs": 1500,
  "RedactionMaxStringLength": 256,
  "MongoServerSelectionTimeoutMs": 1500,
  "MongoConnectTimeoutMs": 1500,
  "RedactionSensitiveKeys": [
    "password",
    "passwd",
    "pwd",
    "token",
    "access_token",
    "refresh_token",
    "secret",
    "apiKey",
    "api_key",
    "authorization",
    "cookie"
  ]
}
